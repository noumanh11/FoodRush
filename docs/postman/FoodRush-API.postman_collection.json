{
  "info": {
    "name": "FoodRush API",
    "description": "FoodRush food ordering platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"New User\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@foodrush.com\",\n  \"password\": \"cust123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Restaurant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"restaurant@foodrush.com\",\n  \"password\": \"rest123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@foodrush.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Restaurants",
      "item": [
        {
          "name": "List Restaurants",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/restaurants"
          }
        },
        {
          "name": "Get Restaurant",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}"
          }
        },
        {
          "name": "Get My Restaurant",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/restaurants/my"
          }
        },
        {
          "name": "Create Restaurant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Restaurant\",\n  \"cuisine\": \"Fast Food\",\n  \"address\": \"Karachi\",\n  \"description\": \"Great food\"\n}"
            },
            "url": "{{baseUrl}}/restaurants"
          }
        }
      ]
    },
    {
      "name": "Menu",
      "item": [
        {
          "name": "Get Menu",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}/menu"
          }
        },
        {
          "name": "Create Menu Item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicken Biryani\",\n  \"price\": 350,\n  \"category\": \"Rice\",\n  \"description\": \"Fragrant basmati rice\",\n  \"isAvailable\": true\n}"
            },
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}/menu"
          }
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 400\n}"
            },
            "url": "{{baseUrl}}/menu/{{menuItemId}}"
          }
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/menu/{{menuItemId}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"menuItemId\": \"{{menuItemId}}\", \"quantity\": 2 }\n  ],\n  \"deliveryAddress\": \"123 Street, Karachi\",\n  \"notes\": \"Extra spicy\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/my"
          }
        },
        {
          "name": "Restaurant Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/restaurant/{{restaurantId}}"
          }
        },
        {
          "name": "All Orders (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/admin/all"
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Cancel Order (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/cancel"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}/status"
          }
        }
      ]
    },
    {
      "name": "Chatbot",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Where can I get biryani?\"\n}"
            },
            "url": "{{baseUrl}}/chatbot/message"
          }
        }
      ]
    }
  ]
}
